{
  "name": "mexion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter @mexion/web dev",
    "dev:web": "pnpm --filter @mexion/web dev",
    "sub2api:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-sub2api.ps1",
    "build": "pnpm --filter @mexion/web build",
    "start": "pnpm --filter @mexion/web preview",
    "lint": "eslint apps/web packages scripts --max-warnings=0",
    "test": "pnpm --filter @mexion/web test",
    "typecheck": "pnpm --filter @mexion/web typecheck",
    "format": "prettier --write .",
    "audit:ui": "bash scripts/audit.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
